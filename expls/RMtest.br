function bin_to_str(bin_str)
    result_str = ""

    for i = 0 to len(bin_str) step 8 then
        bin_byte = bin_str / [i, i + 8, 0]

        if bin_byte == "00000000" then
            break
        end

        result_str += chr(Int(bin_byte, 2))
    end

    return reverse(result_str)
end

test = "Teste"

pointest = pointer(test)

addrtest = address(test)

dectest = deref(addrtest, false, "bin")

ttest = Str(dectest)

println(bin_to_str(ttest))
