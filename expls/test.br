class realCalc
    global xe = 0
    global ye = 0

    x = 0
    y = 0

    function construct(xee, yee, clas)
        global xe = xee
        global ye = yee

        clas.x = xee
        clas.y = yee
    end

    function add()
        return xe + ye
    end

    function sub()
        return xe - ye
    end

    function mul()
        return xe * ye
    end

    function div()
        return xe / ye
    end

    function pow()
        return xe ^ ye
    end

    function rest()
        return xe % ye
    end
end

rc = realCalc()

rc.construct(100, 2, rc)

print(Str(rc.x) + " ÷ " + Str(rc.y) + " = " + Str(rc.div()))