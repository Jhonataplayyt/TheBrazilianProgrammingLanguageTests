class miniCalc
    function add(x, y)
        return x + y
    end

    function sub(x, y)
        return x - y
    end

    function mul(x, y)
        return x * y
    end

    function div(x, y)
        return x / y
    end
end

mnc = miniCalc()

println(mnc.add(7, 8))

println(mnc.sub(6, 5))

println(mnc.mul(3, 9))

println(mnc.div(15, 3))