class Maçã
    cor = null

    function construct(Cor)
        if Cor == "Vermelha" then
            this.cor = 1
        elif Cor = "Verde" then
            this.cor = 2
        else
            error("Erro, aqui são somente Maçãs Vermelhas ou Verdes.")
        end
    end

    function Comer()
        println("Nhãum Nhãum")
        wait(3)

        if this.cor == 1 then
            println("Maçã Vermelha comida.")
        else
            println("Maçã Verde comida.")
        end
    end
end

struct CoresMaçâs
    vermelha
    verde
end

cor = CoresMaçâs{}
cor.vermelha = "Vermelha"
cor.verde = "Verde"

a = null

println("Maçã Vermelha. 1\nMaçã Verde. 2")

while true then
    try
        a = Int(input_key("                        : "))
        println(a)

        if a == 1 then
            🍎 = Maçã()

            println(🍎)

            🍎.construct(cor.vermelha, 🍎)

            🍎.Comer(🍎)

            break
        elif a == 2 then
            🍎 = Maçã()
            🍎.construct(cor.verde, 🍎)

            🍎.Comer(🍎)

            break
        else
            println("Os números precisam ser 1 ou 2.")
        end
    catch as e
        println("Os números precisam ser 1 ou 2.")
    end
end