class Maçã
    cor = null

    function construct(Cor)
        if Cor == "Vermelha" then
            this.cor = 1
        elif Cor = "Verde" then
            this.cor = 2
        else
            error("Erro, aqui são somente Maçãs Vermelhas ou Verdes.")
        end
    end

    function Comer()
        println("Nhãum Nhãum")
        wait(3)

        if this.cor == 1 then
            println("Maçã Vermelha comida.")
        else
            println("Maçã Verde comida.")
        end
    end
end

struct CoresMaçâs
    vermelha
    verde
end

cor = CoresMaçâs{}
cor.vermelha = "Vermelha"
cor.verde = "Verde"

🍎 = Maçã()
🍎.construct(cor.verde, 🍎)

🍎.Comer(🍎)