function cu(a)
    println(a)
end

class miniCalc
    base = 10
    baze = 5

    function add(x, y)
        return x + y
    end

    function sub(x, y)
        return x - y
    end

    function mul(x, y)
        return x * y
    end

    function div(x, y)
        return x / y
    end
end

class realCalc
    global x = null
    global y = null

    function construct(xe, ye)
        global x = xe
        global y = ye
    end

    function add()
        return x + y
    end

    function sub()
        return x - y
    end

    function mul()
        return x * y
    end

    function div()
        return x / y
    end
end

mnc = miniCalc()

println(mnc.sub(mnc.base, mnc.baze))

rc = realCalc()

rc.construct(100, 2)

println(rc.div())