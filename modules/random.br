global aa076 = 25214903917
global cc557 = 11
global mm456 = 2 ^ 16
global seed579 = 42

function randomGeneration(seed, a, c, m)
    return (a * seed + c) % m
end

function randInt(min, max)
    rand_val = randomGeneration(seed579, aa076, cc557, mm456)

    result = min + (rand_val % (max - min + 1))

    global seed579 = result + rand_val

    if (1 + (rand_val % (2 - 1 + 1))) then
        global aa076 = aa076 + 1
    else
        global aa076 += aa076 + 1
    end

    return result
end